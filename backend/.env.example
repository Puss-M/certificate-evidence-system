APP_ENV=development
DATABASE_URL=mysql+pymysql://certificate_app:change-me@127.0.0.1:3306/certificate_evidence?charset=utf8mb4
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_VERIFY_BASE_URL=http://127.0.0.1:5173/public/verify

# 以下三项是测试链接入用的（P2加分项，不填也不影响主线功能，chain_service会自动跳过）。
# 本地起链方式见 chain/README.md；私钥不要提交进git，这份.env.example本身不包含真实私钥。
CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_BACKEND_PRIVATE_KEY=
CHAIN_CONTRACT_ADDRESS=
CHAIN_EXPECTED_CHAIN_IDS=1337,31337
